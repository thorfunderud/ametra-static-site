{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/robots.txt", "/sitemap.xml"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".svg": "image/svg+xml"
  }
}
